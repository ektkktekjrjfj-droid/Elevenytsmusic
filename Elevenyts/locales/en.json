import asyncio
import yt_dlp
from pyrogram import Client, filters
from pyrogram.types import InlineKeyboardMarkup, InlineKeyboardButton, CallbackQuery
from pytgcalls import PyTgCalls
from pytgcalls.types import AudioPiped
import datetime
import config 

# --- CLIENTS SETUP ---
app = Client(
    "KushalMusicBot", 
    api_id=config.API_ID, 
    api_hash=config.API_HASH, 
    bot_token=config.BOT_TOKEN
)

user_app = Client(
    "KushalUserBot", 
    api_id=config.API_ID, 
    api_hash=config.API_HASH, 
    session_string=config.STRING_SESSION
)

call_py = PyTgCalls(user_app)

# --- UI UTILS (Exact Screenshot Style) ---
def get_seekbar(current, total):
    percentage = (current / (total if total > 0 else 1)) * 100
    completed = int(percentage / 10)
    remaining = 10 - completed
    return f"{format_time(current)} {'━' * completed}🔘{'━' * remaining} {format_time(total)}"

def format_time(seconds):
    return str(datetime.timedelta(seconds=int(seconds)))[2:].split('.')[0]

# --- START COMMAND (Private Design) ---
@app.on_message(filters.command("start") & filters.private)
async def start_cmd(client, message):
    start_text = (
        "👋 **WELCOME TO THE MOST POWERFUL MUSIC BOT!**\n\n"
        "✨ **I CAN STREAM HIGH QUALITY MUSIC 24/7 WITHOUT ANY LAG.**\n\n"
        "🥀 **OWNER :** [𝐊𝐔𝐒𝐇𝐀𝐋](https://t.me/Kushal_Owner)\n"
        "📢 **SUPPORT :** [CLICK HERE](https://t.me/KushalStorez)\n\n"
        "**POWERED BY @AHMED_X_STOREZ**"
    )
    await message.reply_text(
        start_text,
        disable_web_page_preview=True,
        reply_markup=InlineKeyboardMarkup([[
            InlineKeyboardButton("➕ ADD ME TO YOUR GROUP", url=f"https://t.me/{client.me.username}?startgroup=true")
        ]])
    )

# --- PLAY HANDLER (Exact Screenshot UI) ---
@app.on_message(filters.command("play") & filters.group)
async def play_music(client, message):
    if len(message.command) < 2:
        return await message.reply_text("🔎 **SEARCHING FOR YOUR TRACK...**")

    query = " ".join(message.command[1:])
    m = await message.reply_text("🔎 **SEARCHING...**")
    chat_id = message.chat.id

    try:
        await call_py.leave_group_call(chat_id)
    except:
        pass

    ydl_opts = {'format': 'bestaudio/best', 'quiet': True, 'noplaylist': True}

    try:
        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
            info = ydl.extract_info(f"ytsearch:{query}", download=False)['entries'][0]
            url = info['url']
            title = info.get('title', 'MUSIC').upper()
            duration_sec = info.get('duration', 0)
            thumb = info.get('thumbnail')
            dur_min = format_time(duration_sec)

        await call_py.join_group_call(chat_id, AudioPiped(url))

        # --- YE RAHA SCREENSHOT WALA EXACT DESIGN ---
        caption = (
            f"➻ **STARTED STREAMING |** ❞\n\n"
            f"✨ **TITLE :** {title[:35]}\n"
            f"⏱ **DURATION :** {dur_min} **MINUTES**\n"
            f"🥀 **REQUESTED BY :** 🦋💸 ⃪♔‌⃟𝐊𝐔𝐒𝐇𝐀𝐋"
        )

        buttons = InlineKeyboardMarkup([
            [InlineKeyboardButton(get_seekbar(0, duration_sec), callback_data="none")],
            [
                InlineKeyboardButton("▷ RESUME", "resume_cb"), 
                InlineKeyboardButton("II PAUSE", "pause_cb")
            ],
            [
                InlineKeyboardButton("↻ REPLAY", "replay_cb"), 
                InlineKeyboardButton("‣‣ SKIP", "skip_cb"), 
                InlineKeyboardButton("▢ STOP", "stop_cb")
            ],
            [InlineKeyboardButton("➕ ADD ME TO YOUR GROUP", url=f"https://t.me/{client.me.username}?startgroup=true")]
        ])

        post = await message.reply_photo(
            photo=thumb if thumb else "https://telegra.ph/file/bc3343358055a40b85354.jpg",
            caption=caption,
            reply_markup=buttons
        )
        await m.delete()

        # Real-time update loop
        curr_time = 0
        while curr_time < duration_sec:
            await asyncio.sleep(15)
            curr_time += 15
            try:
                new_seekbar = get_seekbar(curr_time, duration_sec)
                await post.edit_reply_markup(reply_markup=InlineKeyboardMarkup([
                    [InlineKeyboardButton(new_seekbar, callback_data="none")],
                    [InlineKeyboardButton("▷ RESUME", "resume_cb"), InlineKeyboardButton("II PAUSE", "pause_cb")],
                    [InlineKeyboardButton("↻ REPLAY", "replay_cb"), InlineKeyboardButton("‣‣ SKIP", "skip_cb"), InlineKeyboardButton("▢ STOP", "stop_cb")],
                    [InlineKeyboardButton("➕ ADD ME TO YOUR GROUP", url=f"https://t.me/{client.me.username}?startgroup=true")]
                ]))
            except: break

    except Exception as e:
        await m.edit(f"❌ **ERROR :** `{e}`")

# --- CALLBACK HANDLERS (Systematic Response) ---
@app.on_callback_query()
async def cb_handler(client, query: CallbackQuery):
    chat_id = query.message.chat.id
    if query.data == "pause_cb":
        await call_py.pause_stream(chat_id)
        await query.answer("STREAM PAUSED ⏸", show_alert=True)
    elif query.data == "resume_cb":
        await call_py.resume_stream(chat_id)
        await query.answer("STREAM RESUMED ▶️", show_alert=True)
    elif query.data == "stop_cb":
        await call_py.leave_group_call(chat_id)
        await query.message.delete()
        await query.answer("STREAM STOPPED 🛑")

# --- BOOTING ---
async def start_bot():
    await app.start()
    await user_app.start()
    await call_py.start()
    print("✅ YOUR PREMIUM BOT IS LIVE, KUSHAL BHAI!")
    await asyncio.Event().wait()

if __name__ == "__main__":
    asyncio.get_event_loop().run_until_complete(start_bot())
